#include <stdio.h>
#include <string.h>

struct employe
{
    int id;
    char name[20];
    float salary;
};

struct employe inputemployedata()
{
    struct employe e;
    printf("Enter id, name and salary of an Employee\n");
    scanf("%d", &e.id);
    getchar();
    fgets(e.name, 20, stdin);
    e.name[strlen(e.name) - 1] = '\0';
    scanf("%f", &e.salary);
    return e;
}

void showdata(struct employe e)
{
    printf("Id : %d\n", e.id);
    printf("Name : %s\n", e.name);
    printf("Salary : %.2f\n", e.salary);
}

struct employe HighestSalary(struct employe e[],int n){
    struct employe maxi = e[0];
    for(int i = 1 ; i < n ; i++){
        if(maxi.salary < e[i].salary){
            maxi = e[i];
        }
    }
    return maxi;
}

void sortsalary(struct employe e[],int n){
    for(int i = 1; i < n; i++){
        for(int j = 0; j < n-i; j++){
            if(e[j].salary < e[j+1].salary){
                struct employe temp;
                temp = e[j];
                e[j] = e[j+1];
                e[j+1] = temp;
            }
        }
    }
}

void sortname(struct employe e[],int n){
    for(int i = 1; i < n; i++){
        for(int j = 0; j < n-i; j++){
            if(strcmp(e[j].name,e[j+1].name) > 0){
                struct employe temp;
                temp = e[j];
                e[j] = e[j+1];
                e[j+1] = temp;
            }
        }
    }
}



int main()
{
    struct employe e1;
    e1 = inputemployedata();
    showdata(e1);
    return 0;
}
